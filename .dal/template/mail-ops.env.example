# mail-ops 팀 환경 설정
# dalcenter@mail-ops.service 에서 사용

# dalcenter 리스닝 포트
PORT=

# Mattermost 연동
MM_URL=
MM_TOKEN=
MM_CHANNEL=

# GitHub 연동
GITHUB_TOKEN=
GITHUB_REPO=

# maddy 서버 접근
# CT 122 — 조회: pct list | grep 122
MADDY_CTID=
MADDY_SMTP_PORT=
MADDY_HOST=

# 발신 도메인 설정
MAIL_FROM_DOMAIN=
MAIL_FROM_NAME=

# 모니터링 임계값
BOUNCE_RATE_THRESHOLD=5
QUEUE_SIZE_THRESHOLD=100

# VeilKey (시크릿 관리)
# DKIM 키 등은 veil get <key-name> 으로 조회
VEILKEY_ENDPOINT=
